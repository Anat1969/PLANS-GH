# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# הגדרות סביבה - אפליקציית בדיקה תוכניות בינוי 🏗️
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1️⃣ API KEY - Claude/Anthropic (חובה)
# ──────────────────────────────────────────────────
# קבל מפתח ב: https://console.anthropic.com/
# למערכת Vercel יש להגדיר בחלונית ההגדרות של Vercel
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# גם משתנה חלופי נתמך:
ANAT_KEY_CLOUDE=your_anthropic_api_key_here

# 2️⃣ פיתוח מקומי (Local Development)
# ──────────────────────────────────────────────────
# Node environment
NODE_ENV=development

# URL בסיסי של האפליקציה (פיתוח מקומי)
# בדר"כ תשאר כזו כשמריצים בתוכנית לוקלית
VITE_API_BASE=http://localhost:5173

# 3️⃣ GitHub - עבור שיתוף וקולabortion 🔗
# ──────────────────────────────────────────────────
# מזהה Repository
GITHUB_REPO=anat1969/plans-gh
GITHUB_BRANCH=claude/app-env-file-setup-ifgml7

# GitHub Personal Access Token (אם צריך)
# קבל ב: https://github.com/settings/tokens
# הרשאות דרושות: repo (full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token

# 4️⃣ Vercel Deployment
# ──────────────────────────────────────────────────
# יוגדר ישירות בדashboard של Vercel (לא בקובץ זה)
# URL הדploy:
VERCEL_URL=https://plans-gh.vercel.app

# 5️⃣ תיקיית עבודה
# ──────────────────────────────────────────────────
# תיקיית זמנית לאחסון קבצים
TEMP_DIR=./temp
LOG_DIR=./logs

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# הנחיות להתקנה 📋
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 1. יצירת .env קובץ בתיקייה הראשית של הפרויקט:
#    cp .env.example .env
#
# 2. מילוי משתנים חובה:
#    - ANTHROPIC_API_KEY: קבל ב- https://console.anthropic.com/
#    - GITHUB_TOKEN: קבל ב- https://github.com/settings/tokens
#
# 3. הקפדה חשובה:
#    - לעולם אל תדחוף את קובץ .env לGit!
#    - רק .env.example צריך להיות ב-Git
#    - .env כבר בקובץ .gitignore ✓
#
# 4. לDeploy ב-Vercel:
#    - זהה משתנים ב-Vercel Dashboard → Settings → Environment Variables
#    - או דרך CLI: vercel env pull
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# קישורים שימושיים 🔗
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 📚 Claude API Docs: https://docs.anthropic.com/
# 🔧 Vercel Dashboard: https://vercel.com/dashboard
# 🐙 GitHub Repo: https://github.com/anat1969/plans-gh
# 🚀 Local Dev: npm install && npm run dev
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
